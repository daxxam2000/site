# Build and deploy the Jekyll site to GitHub Pages.
#
# This workflow replaces GitHub's legacy "Deploy from a branch" mode (which uses
# the ancient `github-pages` gem) with a modern Jekyll 4 build pipeline.
#
# One-time setup in the repo: Settings → Pages → Build and deployment →
#   Source: GitHub Actions
#
# After that, every push to `main` triggers this workflow.

name: Deploy site to Pages

on:
  push:
    branches: [main]
  # Allow manual runs from the Actions tab.
  workflow_dispatch:

# Permissions the deploy job needs to publish to Pages.
permissions:
  contents: read
  pages: write
  id-token: write

# Allow only one Pages deploy at a time. Don't cancel in-progress runs —
# we want each push to finish so the user gets feedback.
concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: "3.3"
          bundler-cache: true   # caches gems between runs

      - name: Configure Pages
        id: pages
        uses: actions/configure-pages@v5

      - name: Build site
        run: bundle exec jekyll build --baseurl "${{ steps.pages.outputs.base_path }}"
        env:
          JEKYLL_ENV: production

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        # Defaults to uploading ./_site, which is exactly what `jekyll build` writes.

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
