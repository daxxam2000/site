source "https://rubygems.org"

# This pin keeps your local builds matched to whatever version GitHub Pages
# is currently running. Update with `bundle update github-pages` periodically.
gem "github-pages", group: :jekyll_plugins

# Plugins (these are also listed in _config.yml so GH Pages enables them).
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-paginate"
end

# Stdlib gems unbundled in Ruby 3.4+ that GitHub Pages' Jekyll still needs.
# Without these, Jekyll fails on `require 'csv'` (and then logger, base64, etc.)
# when run on Ruby 3.4 or newer.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "mutex_m"
gem "ostruct"

# Liquid 4.0.3 (pulled in by older github-pages) calls String#tainted? which
# Ruby 3.2+ removed. Force a newer Liquid that fixed this regression.
gem "liquid", ">= 4.0.4"

# Windows / JRuby compatibility shims.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]
gem "http_parser.rb", "~> 0.6.0", :platforms => [:jruby]
